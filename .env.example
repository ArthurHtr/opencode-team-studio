# Path to your OpenCode configuration directory on the host machine.
# This directory is mounted into the container at /config.
OPENCODE_HOST_CONFIG_DIR=/home/your-user/.config/opencode

# Container user UID/GID — should match the owner of OPENCODE_HOST_CONFIG_DIR
LOCAL_UID=1000
LOCAL_GID=1000

# Host port mapping (container always listens on port 3000)
STUDIO_PORT=3210

# Image version to deploy
STUDIO_VERSION=0.1.0-alpha.1
